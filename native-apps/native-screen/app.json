{
  "expo": {
    "plugins": [
      [
        "@react-native-tvos/config-tv",
        {
          "isTV": true,
          "androidTVBanner": "./assets/images/icon-1280x720.png",
          "androidTVIcon": "./assets/images/icon-512x512.png",
          "appleTVImages": {
            "icon": "./assets/images/icon-1280x768.png",
            "iconSmall": "./assets/images/icon-400x240.png",
            "iconSmall2x": "./assets/images/icon-800x480.png",
            "topShelf": "./assets/images/icon-1920x720.png",
            "topShelf2x": "./assets/images/icon-3840x1440.png",
            "topShelfWide": "./assets/images/icon-2320x720.png",
            "topShelfWide2x": "./assets/images/icon-4640x1440.png"
          }
        }
      ],
      "expo-router",
      "./plugins/withCleartextTraffic.js",
      "./plugins/withLeanbackRequired.js",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/brand.png",
          "backgroundColor": "#000000",
          "imageWidth": 400,
          "resizeMode": "contain"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "orientation": "landscape",
    "icon": "./assets/images/icon.png",
    "scheme": "theopenpresenter",
    "name": "TheOpenPresenter TV",
    "slug": "TheOpenPresenter-tv",
    "version": "1.0.1",
    "android": {
      "package": "com.theopenpresenter.tv"
    },
    "ios": {
      "bundleIdentifier": "com.theopenpresenter.tv"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "vija02",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1336fc03-9568-45c6-b040-85142bd386b0"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/1336fc03-9568-45c6-b040-85142bd386b0"
    }
  }
}