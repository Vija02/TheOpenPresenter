---
---

<section>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="py-12 md:py-20 border-t border-gray-200 dark:border-gray-800">
      <!-- Section header -->
      <div class="max-w-3xl mx-auto text-center pb-12 md:pb-14">
        <div
          class="inline-flex items-center text-sm font-semibold tracking-wide uppercase text-teal-500 mb-3"
        >
          Calling all developers
        </div>
        <h2 class="h2 mb-4 font-red-hat-display">
          Use your skills for the kingdom of God
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-400">
          TheOpenPresenter is open source and fully modular. Everything is a plugin. So if your church needs something specific, you can easily extend TheOpenPresenter to get it to work.
        </p>
      </div>

      <!-- Items -->
      <div
        class="max-w-xs mx-auto sm:max-w-none grid gap-6 md:grid-cols-3"
        data-aos-id-churchplugins
      >
        <!-- Modular plugin system -->
        <div
          class="flex flex-col p-6 group text-white bg-linear-to-tr from-teal-500 to-teal-400 dark:to-teal-500 shadow-2xl rounded-lg"
          data-aos="fade-down"
          data-aos-anchor="[data-aos-id-churchplugins]"
        >
          <svg class="w-8 h-8 mb-3 fill-current" viewBox="0 0 24 24">
            <path
              d="M12 2a2 2 0 0 1 2 2v2h2.5A1.5 1.5 0 0 1 18 7.5V10h2a2 2 0 1 1 0 4h-2v4a2 2 0 0 1-2 2h-4v-2a2 2 0 1 0-4 0v2H4a2 2 0 0 1-2-2v-4h2a2 2 0 1 0 0-4H2V7.5A1.5 1.5 0 0 1 3.5 6H10V4a2 2 0 0 1 2-2z"
            ></path>
          </svg>
          <div
            class="font-red-hat-display text-xl font-black tracking-tighter mb-1"
          >
            A modular plugin system
          </div>
          <div class="grow opacity-80">
            Everything is a plugin: lyrics, slides, video, Bible verses. Build
            new ones against a clean API and drop them straight in.
          </div>
        </div>

        <!-- Open source -->
        <div
          class="flex flex-col p-6 group text-white bg-linear-to-tr from-purple-500 to-purple-400 dark:to-purple-500 shadow-2xl rounded-lg"
          data-aos="fade-down"
          data-aos-anchor="[data-aos-id-churchplugins]"
          data-aos-delay="100"
        >
          <svg class="w-8 h-8 mb-3 fill-current" viewBox="0 0 24 24">
            <path
              d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0L19.2 12l-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"
            ></path>
          </svg>
          <div
            class="font-red-hat-display text-xl font-black tracking-tighter mb-1"
          >
            Open source, hack away
          </div>
          <div class="grow opacity-80">
            It's all on GitHub under AGPL 3.0. Read the code, send a pull
            request, self-host or fork it. The project is the community's.
          </div>
        </div>

        <!-- Use AI -->
        <div
          class="flex flex-col p-6 group text-white bg-linear-to-tr from-indigo-500 to-indigo-400 dark:to-indigo-500 shadow-2xl rounded-lg"
          data-aos="fade-down"
          data-aos-anchor="[data-aos-id-churchplugins]"
          data-aos-delay="200"
        >
          <svg class="w-8 h-8 mb-3 fill-current" viewBox="0 0 24 24">
            <path
              d="M12 2l2.4 5.6L20 10l-5.6 2.4L12 18l-2.4-5.6L4 10l5.6-2.4L12 2zm7 12l1.2 2.8L23 18l-2.8 1.2L19 22l-1.2-2.8L15 18l2.8-1.2L19 14z"
            ></path>
          </svg>
          <div
            class="font-red-hat-display text-xl font-black tracking-tighter mb-1"
          >
            Build it with AI
          </div>
          <div class="grow opacity-80">
            Not a full-time dev? Describe what you need and use AI to scaffold a
            simple plugin. A little code knowledge goes a long way.
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center mt-10" data-aos="fade-up">
        <a
          class="btn text-white bg-gray-900 hover:bg-gray-700 dark:bg-white dark:text-gray-900 dark:hover:bg-gray-200"
          href="https://github.com/Vija02/TheOpenPresenter"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="w-5 h-5 fill-current mr-2" viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
            ></path>
          </svg>
          Explore the code on GitHub
        </a>
      </div>
    </div>
  </div>
</section>
