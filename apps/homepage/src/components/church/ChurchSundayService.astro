---
---

<section>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="py-12 md:py-20 border-t border-gray-200 dark:border-gray-800">
      <!-- Section header -->
      <div class="max-w-2xl mx-auto text-center pb-10 md:pb-12">
        <div
          class="inline-flex items-center text-sm font-semibold tracking-wide uppercase text-teal-500 mb-2"
        >
          For Sunday Service
        </div>
        <h2 class="h2 mb-4 font-red-hat-display">
          Improve your Sunday experience
        </h2>
        <p class="text-gray-600 dark:text-gray-400">
          Prepare everything ahead of time. Make Sunday setup simple.
        </p>
      </div>

      <!-- Point 1: Prepare offsite in the cloud -->
      <div
        class="md:grid md:grid-cols-12 md:gap-12 lg:gap-20 items-center mb-12 md:mb-20"
      >
        <div
          class="md:col-span-6 mb-8 md:mb-0 text-center md:text-left"
          data-aos="fade-right"
        >
          <div
            class="flex items-center justify-center w-12 h-12 rounded-full text-white font-red-hat-display font-black text-xl mb-4 mx-auto md:mx-0 bg-linear-to-tr from-teal-500 to-teal-400"
          >
            1
          </div>
          <h3 class="text-xl md:text-2xl font-red-hat-display font-black mb-3">
            Prepare offsite, any day of the week
          </h3>
          <p class="text-lg text-gray-600 dark:text-gray-400 mb-4">
            Everything lives in the cloud, so you can build the whole
            service during the week, online. Nothing
            waits until Sunday morning and nothing is stuck on one person's
            laptop.
          </p>
          <ul class="text-gray-600 dark:text-gray-400 text-left inline-block">
            <li class="flex items-start mb-2">
              <svg
                class="w-3 h-3 fill-current text-teal-400 mr-2 mt-1.5 shrink-0"
                viewBox="0 0 12 12"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                ></path>
              </svg>
              <span>Prepare from anywhere, on any device</span>
            </li>
            <li class="flex items-start mb-2">
              <svg
                class="w-3 h-3 fill-current text-teal-400 mr-2 mt-1.5 shrink-0"
                viewBox="0 0 12 12"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                ></path>
              </svg>
              <span>Nothing tied to a single church laptop</span>
            </li>
          </ul>
        </div>
        <div class="md:col-span-6" data-aos="fade-left">
          <!-- Cloud service-plan illustration -->
          <div
            class="relative rounded-xl bg-gray-100 dark:bg-gray-800 p-5 shadow-2xl ring-1 ring-gray-200 dark:ring-gray-700"
          >
            <div
              class="rounded-lg bg-white dark:bg-gray-900 p-4 ring-1 ring-gray-200 dark:ring-gray-700"
            >
              <div class="flex items-center justify-between mb-4">
                <div class="text-[10px] uppercase tracking-wide text-gray-400">
                  Sunday service
                </div>
                <!-- Collaborator avatars -->
                <div class="flex -space-x-2">
                  <span
                    class="w-5 h-5 rounded-full bg-teal-500 ring-2 ring-white dark:ring-gray-900"
                  ></span>
                  <span
                    class="w-5 h-5 rounded-full bg-purple-500 ring-2 ring-white dark:ring-gray-900"
                  ></span>
                  <span
                    class="w-5 h-5 rounded-full bg-indigo-500 ring-2 ring-white dark:ring-gray-900"
                  ></span>
                </div>
              </div>
              <div class="space-y-2.5">
                <div class="flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-teal-400 shrink-0"></span>
                  <div class="h-2 rounded bg-gray-200 dark:bg-gray-700 w-1/3"></div>
                </div>
                <div class="flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-purple-400 shrink-0"></span>
                  <div class="h-2 rounded bg-gray-200 dark:bg-gray-700 w-2/3"></div>
                </div>
                <div class="flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 shrink-0"></span>
                  <div class="h-2 rounded bg-gray-200 dark:bg-gray-700 w-1/2"></div>
                </div>
                <div class="flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-pink-400 shrink-0"></span>
                  <div class="h-2 rounded bg-gray-200 dark:bg-gray-700 w-3/5"></div>
                </div>
              </div>
            </div>
            <!-- Cloud badge -->
            <div
              class="absolute -top-3 left-1/2 -translate-x-1/2 inline-flex items-center gap-1 rounded-full bg-gray-900 dark:bg-gray-700 text-white text-xs font-semibold px-3 py-1 shadow-lg"
            >
              <svg class="w-3.5 h-3.5 fill-current text-teal-400" viewBox="0 0 24 24">
                <path
                  d="M19 18H6a4 4 0 0 1-.6-7.95 5.5 5.5 0 0 1 10.8-1.2A4.5 4.5 0 0 1 19 18z"
                ></path>
              </svg>
              Synced to the cloud
            </div>
          </div>
        </div>
      </div>

      <!-- Point 2: Build it in Google Slides -->
      <div class="md:grid md:grid-cols-12 md:gap-12 lg:gap-20 items-center">
        <div
          class="md:col-span-6 mb-8 md:mb-0 text-center md:text-left md:order-2"
          data-aos="fade-left"
        >
          <div
            class="flex items-center justify-center w-12 h-12 rounded-full text-white font-red-hat-display font-black text-xl mb-4 mx-auto md:mx-0 bg-linear-to-tr from-purple-500 to-purple-400"
          >
            2
          </div>
          <h3 class="text-xl md:text-2xl font-red-hat-display font-black mb-3">
            Build it in Google Slides, together
          </h3>
          <p class="text-lg text-gray-600 dark:text-gray-400 mb-4">
            Make your slides in Google Slides to collaborate together.
            Everyone can work on announcements, the sermon and more at the same
            time. When it's ready, sync it straight into TheOpenPresenter.
          </p>
          <ul class="text-gray-600 dark:text-gray-400 text-left inline-block">
            <li class="flex items-start mb-2">
              <svg
                class="w-3 h-3 fill-current text-teal-400 mr-2 mt-1.5 shrink-0"
                viewBox="0 0 12 12"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                ></path>
              </svg>
              <span>Collaborate on slides in real time</span>
            </li>
            <li class="flex items-start mb-2">
              <svg
                class="w-3 h-3 fill-current text-teal-400 mr-2 mt-1.5 shrink-0"
                viewBox="0 0 12 12"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                ></path>
              </svg>
              <span>One-click sync. More sync integrations coming</span>
            </li>
          </ul>
        </div>
        <div class="md:col-span-6 md:order-1" data-aos="fade-right">
          <!-- Google Slides workflow illustration -->
          <div
            class="relative rounded-xl bg-linear-to-tr from-purple-500 to-indigo-500 p-8 shadow-2xl overflow-hidden"
          >
            <div class="flex items-center justify-between gap-2">
              <!-- Google Slides -->
              <div
                class="flex-1 flex flex-col items-center text-center gap-2 rounded-lg bg-white shadow-lg p-3"
              >
                <div
                  class="flex items-center justify-center w-9 h-9 rounded-lg bg-amber-400 text-white"
                >
                  <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                    <path d="M6 2h8l4 4v16H6V2zm2 9h8v2H8v-2zm0 4h8v2H8v-2z"></path>
                  </svg>
                </div>
                <span class="text-[11px] font-medium text-gray-700 leading-tight"
                  >Google Slides</span
                >
              </div>
              <svg
                class="w-5 h-5 fill-current text-white/80 shrink-0"
                viewBox="0 0 24 24"
              >
                <path d="M13 5l7 7-7 7-1.4-1.4 4.6-4.6H4v-2h12.2l-4.6-4.6z"></path>
              </svg>
              <!-- Sync -->
              <div
                class="flex-1 flex flex-col items-center text-center gap-2 rounded-lg bg-white shadow-lg p-3"
              >
                <div
                  class="flex items-center justify-center w-9 h-9 rounded-lg bg-teal-500 text-white"
                >
                  <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                    <path d="M12 4V1L8 5l4 4V6a6 6 0 1 1-6 6H4a8 8 0 1 0 8-8z"></path>
                  </svg>
                </div>
                <span class="text-[11px] font-medium text-gray-700 leading-tight"
                  >Sync</span
                >
              </div>
              <svg
                class="w-5 h-5 fill-current text-white/80 shrink-0"
                viewBox="0 0 24 24"
              >
                <path d="M13 5l7 7-7 7-1.4-1.4 4.6-4.6H4v-2h12.2l-4.6-4.6z"></path>
              </svg>
              <!-- On screen -->
              <div
                class="flex-1 flex flex-col items-center text-center gap-2 rounded-lg bg-white shadow-lg p-3"
              >
                <div
                  class="flex items-center justify-center w-9 h-9 rounded-lg bg-indigo-500 text-white"
                >
                  <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                    <path
                      d="M21 3H3a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h7v2H8v2h8v-2h-2v-2h7a1 1 0 0 0 1-1V4a1 1 0 0 0-1-1z"
                    ></path>
                  </svg>
                </div>
                <span class="text-[11px] font-medium text-gray-700 leading-tight"
                  >On the screen</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
