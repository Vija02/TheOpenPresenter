---
---

<section>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="py-12 md:py-20 border-t border-gray-200 dark:border-gray-800">
      <!-- Section header -->
      <div class="max-w-2xl mx-auto text-center pb-10 md:pb-12">
        <div
          class="inline-flex items-center text-sm font-semibold tracking-wide uppercase text-teal-500 mb-2"
        >
          For mid-week meetings
        </div>
        <h2 class="h2 mb-4 font-red-hat-display">
          Just as easy for mid-week meetings
        </h2>
        <p class="text-gray-600 dark:text-gray-400">
          Home groups, Bible studies, prayer nights and youth. Same tools with no overhead.
        </p>
      </div>

      <!-- Point 1: Just bring a TV stick -->
      <div
        class="md:grid md:grid-cols-12 md:gap-12 lg:gap-20 items-center mb-12 md:mb-20"
      >
        <div
          class="md:col-span-6 mb-8 md:mb-0 text-center md:text-left"
          data-aos="fade-right"
        >
          <div
            class="flex items-center justify-center w-12 h-12 rounded-full text-white font-red-hat-display font-black text-xl mb-4 mx-auto md:mx-0 bg-linear-to-tr from-teal-500 to-teal-400"
          >
            1
          </div>
          <h3 class="text-xl md:text-2xl font-red-hat-display font-black mb-3">
            Just bring a TV stick, no laptop needed
          </h3>
          <p class="text-lg text-gray-600 dark:text-gray-400 mb-4">
            Plug a TV stick like a Fire TV Stick into the venue's screen and
            you're ready. Nothing to wire up, nothing heavy to carry. Leave the
            laptop at home.
          </p>
          <ul class="text-gray-600 dark:text-gray-400 text-left inline-block">
            <li class="flex items-start mb-2">
              <svg
                class="w-3 h-3 fill-current text-teal-400 mr-2 mt-1.5 shrink-0"
                viewBox="0 0 12 12"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                ></path>
              </svg>
              <span>Works on Fire TV, Chromecast, and other platforms</span>
            </li>
            <li class="flex items-start mb-2">
              <svg
                class="w-3 h-3 fill-current text-teal-400 mr-2 mt-1.5 shrink-0"
                viewBox="0 0 12 12"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                ></path>
              </svg>
              <span>Pocket-sized - fits in your bag</span>
            </li>
          </ul>
        </div>
        <div class="md:col-span-6" data-aos="fade-left">
          <!-- TV + stick illustration -->
          <div
            class="relative rounded-xl bg-gray-100 dark:bg-gray-800 p-8 shadow-2xl ring-1 ring-gray-200 dark:ring-gray-700"
          >
            <!-- TV -->
            <div class="mx-auto max-w-xs">
              <div
                class="rounded-lg bg-gray-900 ring-1 ring-black/20 p-3 shadow-xl aspect-video flex flex-col items-center justify-center text-center"
              >
                <div class="h-2 rounded bg-white/80 w-2/3 mb-2"></div>
                <div class="h-2 rounded bg-white/50 w-1/2"></div>
              </div>
              <div class="h-3 w-16 mx-auto bg-gray-300 dark:bg-gray-600"></div>
              <div
                class="h-1.5 w-28 mx-auto rounded-full bg-gray-300 dark:bg-gray-600"
              ></div>
            </div>
            <!-- TV stick chip -->
            <div
              class="absolute top-6 right-6 inline-flex items-center gap-1.5 rounded-full bg-indigo-500 text-white text-xs font-semibold px-3 py-1 shadow-lg"
            >
              <svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24">
                <rect x="3" y="9" width="14" height="6" rx="3"></rect>
                <rect x="17" y="11" width="4" height="2" rx="1"></rect>
              </svg>
              TV stick
            </div>
            <!-- No laptop chip -->
            <div
              class="absolute -bottom-3 left-6 inline-flex items-center gap-1.5 rounded-full bg-gray-900 dark:bg-gray-700 text-white text-xs font-semibold px-3 py-1 shadow-lg"
            >
              <svg class="w-3.5 h-3.5 fill-current text-teal-400" viewBox="0 0 24 24">
                <path
                  d="M2.39 1.73L1.11 3l3.54 3.54A2 2 0 0 0 4 8v9H2v2h15.11l2.84 2.84 1.27-1.27L2.39 1.73zM6 8.89L14.11 17H6V8.89zM8.2 5H20v9.8l1.6 1.6c.25-.3.4-.69.4-1.1V5a2 2 0 0 0-2-2H6.2l2 2z"
                ></path>
              </svg>
              No laptop needed
            </div>
          </div>
        </div>
      </div>

      <!-- Point 2: Control from any device -->
      <div class="md:grid md:grid-cols-12 md:gap-12 lg:gap-20 items-center">
        <div
          class="md:col-span-6 mb-8 md:mb-0 text-center md:text-left md:order-2"
          data-aos="fade-left"
        >
          <div
            class="flex items-center justify-center w-12 h-12 rounded-full text-white font-red-hat-display font-black text-xl mb-4 mx-auto md:mx-0 bg-linear-to-tr from-purple-500 to-purple-400"
          >
            2
          </div>
          <h3 class="text-xl md:text-2xl font-red-hat-display font-black mb-3">
            Control from any device
          </h3>
          <p class="text-lg text-gray-600 dark:text-gray-400 mb-4">
            Run everything from whatever's in your hand. A phone, a tablet, an
            iPad. Keep everything simple and everyone can control with their own devices at the same time.
          </p>
          <ul class="text-gray-600 dark:text-gray-400 text-left inline-block">
            <li class="flex items-start mb-2">
              <svg
                class="w-3 h-3 fill-current text-teal-400 mr-2 mt-1.5 shrink-0"
                viewBox="0 0 12 12"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                ></path>
              </svg>
              <span>Phone, tablet or iPad - whatever you have</span>
            </li>
            <li class="flex items-start mb-2">
              <svg
                class="w-3 h-3 fill-current text-teal-400 mr-2 mt-1.5 shrink-0"
                viewBox="0 0 12 12"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                ></path>
              </svg>
              <span>Everyone control with their own devices</span>
            </li>
          </ul>
        </div>
        <div class="md:col-span-6 md:order-1" data-aos="fade-right">
          <!-- Devices illustration -->
          <div
            class="relative rounded-xl bg-linear-to-tr from-purple-500 to-indigo-500 p-8 shadow-2xl overflow-hidden"
          >
            <div class="flex items-end justify-center gap-4">
              <!-- Phone -->
              <div
                class="w-16 h-28 rounded-[0.9rem] bg-white shadow-lg ring-1 ring-black/10 p-1.5 flex flex-col"
              >
                <div class="rounded-md bg-gray-900 grow"></div>
                <div class="h-1 w-6 mx-auto mt-1 rounded-full bg-gray-300"></div>
              </div>
              <!-- Tablet -->
              <div
                class="w-20 h-28 rounded-xl bg-white shadow-lg ring-1 ring-black/10 p-1.5"
              >
                <div class="rounded-md bg-gray-900 w-full h-full"></div>
              </div>
              <!-- iPad (larger) -->
              <div
                class="w-28 h-32 rounded-xl bg-white shadow-lg ring-1 ring-black/10 p-2"
              >
                <div class="rounded-md bg-gray-900 w-full h-full"></div>
              </div>
            </div>
            <!-- Badge -->
            <div
              class="mt-6 mx-auto inline-flex items-center gap-1.5 rounded-full bg-white/15 backdrop-blur text-white text-xs font-semibold px-3 py-1"
            >
              <span class="w-2 h-2 rounded-full bg-teal-300 animate-pulse"></span>
              Any device works
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
