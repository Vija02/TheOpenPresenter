---
---

<section>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="py-12 md:py-20 border-t border-gray-200 dark:border-gray-800">
      <!-- Section header -->
      <div class="max-w-3xl mx-auto text-center pb-12 md:pb-14">
        <h2 class="h2 mb-4 font-red-hat-display">Two ways to use it</h2>
        <p class="text-lg text-gray-600 dark:text-gray-400">
          Run it yourself with the free, open-source app, or let us host the
          cloud for you. Either way, small churches are covered.
        </p>
      </div>

      <!-- Two options -->
      <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto items-stretch">
        <!-- Studio -->
        <div
          id="studio"
          class="relative flex flex-col h-full p-8 rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-800 scroll-mt-24"
          data-aos="fade-right"
        >
          <div
            class="inline-flex items-center justify-center w-12 h-12 rounded-xl text-white mb-5 bg-linear-to-tr from-teal-500 to-teal-400"
          >
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24">
              <path
                d="M21 3H3a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h7v2H8v2h8v-2h-2v-2h7a1 1 0 0 0 1-1V4a1 1 0 0 0-1-1z"
              ></path>
            </svg>
          </div>
          <h3 class="font-red-hat-display text-2xl font-black mb-1">
            TheOpenPresenter Studio
          </h3>
          <div class="text-teal-500 font-semibold mb-4">
            Offline Desktop app
          </div>
          <p class="text-gray-600 dark:text-gray-400 mb-5">
            A desktop app similar to traditional software that you'd be familar with like ProPresenter, EasyWorship and the likes. Everything runs on your laptop or PC, no account needed. <br><br>Connect to the cloud server for collaboration. When connected, you also get access to control your show from anywhere.
          </p>
          <ul class="text-gray-600 dark:text-gray-400 space-y-2 mb-6 grow">
            <li class="flex items-start">
              <svg
                class="w-3 h-3 fill-current text-teal-400 mr-2 mt-1.5 shrink-0"
                viewBox="0 0 12 12"
              >
                <path
                  d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                ></path>
              </svg>
              <span>Best for the laptop or PC at the front</span>
            </li>
            <li class="flex items-start">
              <svg
                class="w-3 h-3 fill-current text-teal-400 mr-2 mt-1.5 shrink-0"
                viewBox="0 0 12 12"
              >
                <path
                  d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                ></path>
              </svg>
              <span>Open source under AGPL 3.0</span>
            </li>
          </ul>
          <a
            class="btn-sm text-white bg-teal-500 hover:bg-teal-400 self-start"
            href="/download#studio"
          >
            Download Studio
          </a>
        </div>

        <!-- Cloud -->
        <div
          class="relative flex flex-col h-full p-8 rounded-2xl border-2 border-teal-500 bg-white dark:bg-gray-800 shadow-xl"
          data-aos="fade-left"
        >
          <div
            class="absolute top-0 right-0 -mt-3 mr-5 inline-flex items-center gap-1 rounded-full bg-teal-500 text-white text-xs font-semibold px-3 py-1 shadow-lg"
          >
            <svg class="w-3 h-3 fill-current" viewBox="0 0 24 24">
              <path
                d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
              ></path>
            </svg>
            Free for small churches
          </div>
          <div
            class="inline-flex items-center justify-center w-12 h-12 rounded-xl text-white mb-5 bg-linear-to-tr from-purple-500 to-purple-400"
          >
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24">
              <path
                d="M19 18H6a4 4 0 0 1-.6-7.95 5.5 5.5 0 0 1 10.8-1.2A4.5 4.5 0 0 1 19 18z"
              ></path>
            </svg>
          </div>
          <h3 class="font-red-hat-display text-2xl font-black mb-1">
            TheOpenPresenter Cloud
          </h3>
          <div class="text-purple-500 font-semibold mb-4">Online app, hosted for you</div>
          <p class="text-gray-600 dark:text-gray-400 mb-5">
            Access and present everything online directly from your browser. Always available and free for small churches so you don't have to manage your own.
            <br><br>Use one of our many apps for native presenting. Available for Desktop or TV systems like Android TV and Fire TV.
          </p>
          <ul class="text-gray-600 dark:text-gray-400 space-y-2 mb-6 grow">
            <li class="flex items-start">
              <svg
                class="w-3 h-3 fill-current text-teal-400 mr-2 mt-1.5 shrink-0"
                viewBox="0 0 12 12"
              >
                <path
                  d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                ></path>
              </svg>
              <span>Collaborate out of the box, nothing to maintain</span>
            </li>
            <li class="flex items-start">
              <svg
                class="w-3 h-3 fill-current text-teal-400 mr-2 mt-1.5 shrink-0"
                viewBox="0 0 12 12"
              >
                <path
                  d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                ></path>
              </svg>
              <span>Under 50 weekly attendance? It's free through our sponsorship program</span>
            </li>
          </ul>
          <a
            class="btn-sm text-white bg-teal-500 hover:bg-teal-400 self-start"
            href="/register"
          >
            Try it now
          </a>
        </div>
      </div>

      <!-- Sponsorship -->
      <div
        class="max-w-4xl mx-auto mt-6 rounded-2xl bg-teal-50 dark:bg-teal-500/10 border border-teal-200 dark:border-teal-500/30 p-8"
        data-aos="fade-up"
      >
        <div class="md:flex md:items-start md:gap-6">
          <div
            class="shrink-0 flex items-center justify-center w-12 h-12 rounded-xl text-white mb-4 md:mb-0 bg-linear-to-tr from-teal-500 to-teal-400"
          >
            <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24">
              <path
                d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
              ></path>
            </svg>
          </div>
          <div class="grow">
            <h3 class="font-red-hat-display text-2xl font-black mb-2">
              The small-church sponsorship
            </h3>
            <p class="text-gray-700 dark:text-gray-300 mb-5">
              If your church has under 50 weekly attendance, the full cloud plan
              is yours free, storage and AI credits included. It will always be
              available and never taken away. We believe that small churches are key to fulfiling the Great Commision. And this is just our small part in that. If you're ever able to give back
              you're welcome to
              <a
                class="text-teal-600 dark:text-teal-400 hover:underline font-medium"
                href="/church/donate">donate</a
              >, but there's never any obligation.
            </p>

            <!-- What's included -->
            <ul class="grid sm:grid-cols-2 gap-x-6 gap-y-2 mb-6">
              <li class="flex items-start text-gray-700 dark:text-gray-300">
                <svg
                  class="w-3 h-3 fill-current text-teal-500 mr-2 mt-1.5 shrink-0"
                  viewBox="0 0 12 12"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>The full cloud plan, hosted for you</span>
              </li>
              <li class="flex items-start text-gray-700 dark:text-gray-300">
                <svg
                  class="w-3 h-3 fill-current text-teal-500 mr-2 mt-1.5 shrink-0"
                  viewBox="0 0 12 12"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>Storage included</span>
              </li>
              <li class="flex items-start text-gray-700 dark:text-gray-300">
                <svg
                  class="w-3 h-3 fill-current text-teal-500 mr-2 mt-1.5 shrink-0"
                  viewBox="0 0 12 12"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>AI credits included</span>
              </li>
              <li class="flex items-start text-gray-700 dark:text-gray-300">
                <svg
                  class="w-3 h-3 fill-current text-teal-500 mr-2 mt-1.5 shrink-0"
                  viewBox="0 0 12 12"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>Always free, never taken away</span>
              </li>
            </ul>

            <a
              class="btn-sm text-white bg-teal-500 hover:bg-teal-400"
            href="/church/sponsorship"
          >
            Apply for a sponsorship
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
