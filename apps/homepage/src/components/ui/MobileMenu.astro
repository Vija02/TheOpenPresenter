---

---

<div class="inline-flex md:hidden">
  <ul class="flex justify-end flex-wrap items-center gap-2">
    <li>
      <a href="/login" class="btn-sm text-white bg-teal-500 hover:bg-teal-400">
        Login
      </a>
    </li>
    <li class="relative">
      <button
        type="button"
        id="mobile-menu-toggle"
        class="flex items-center justify-center w-10 h-10 rounded-md text-gray-200 hover:bg-gray-800 transition-colors"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu-panel"
      >
        <svg
          class="w-6 h-6"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="4" y1="6" x2="20" y2="6"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="18" x2="20" y2="18"></line>
        </svg>
      </button>
      <div
        id="mobile-menu-panel"
        class="hidden absolute right-0 mt-2 min-w-[12rem] rounded-md bg-gray-900 ring-1 ring-gray-700 shadow-lg py-1 z-50"
      >
        <a
          href="/download"
          class="block px-4 py-2 text-gray-200 hover:bg-gray-800 transition-colors"
        >
          Downloads
        </a>
        <a
          href="/connect"
          class="block px-4 py-2 text-gray-200 hover:bg-gray-800 transition-colors"
        >
          Connect to Screen
        </a>
        <a
          href="https://github.com/Vija02/TheOpenPresenter"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 px-4 py-2 text-gray-200 hover:bg-gray-800 transition-colors"
        >
          GitHub
          <svg
            class="w-7 h-7 fill-current"
            viewBox="0 0 32 32"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="M16 8.2c-4.4 0-8 3.6-8 8 0 3.5 2.3 6.5 5.5 7.6.4.1.5-.2.5-.4V22c-2.2.5-2.7-1-2.7-1-.4-.9-.9-1.2-.9-1.2-.7-.5.1-.5.1-.5.8.1 1.2.8 1.2.8.7 1.3 1.9.9 2.3.7.1-.5.3-.9.5-1.1-1.8-.2-3.6-.9-3.6-4 0-.9.3-1.6.8-2.1-.1-.2-.4-1 .1-2.1 0 0 .7-.2 2.2.8.6-.2 1.3-.3 2-.3s1.4.1 2 .3c1.5-1 2.2-.8 2.2-.8.4 1.1.2 1.9.1 2.1.5.6.8 1.3.8 2.1 0 3.1-1.9 3.7-3.7 3.9.3.4.6.9.6 1.6v2.2c0 .2.1.5.6.4 3.2-1.1 5.5-4.1 5.5-7.6-.1-4.4-3.7-8-8.1-8z"
            ></path>
          </svg>
        </a>
      </div>
    </li>
  </ul>
</div>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const panel = document.getElementById("mobile-menu-panel");

  if (toggle && panel) {
    const close = () => {
      panel.classList.add("hidden");
      toggle.setAttribute("aria-expanded", "false");
    };

    toggle.addEventListener("click", (e) => {
      e.stopPropagation();
      const open = panel.classList.toggle("hidden") === false;
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
    });

    // Close when clicking anywhere outside the menu.
    document.addEventListener("click", (e) => {
      if (panel.classList.contains("hidden")) return;
      const target = e.target as Node;
      if (!panel.contains(target) && !toggle.contains(target)) close();
    });

    // Close on Escape for keyboard users.
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });
  }
</script>
