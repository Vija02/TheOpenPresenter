---
---

<!-- How does it work -->
<section>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="py-12 md:py-20 border-t border-gray-200 dark:border-gray-800">
      <!-- Section header -->
      <div class="max-w-3xl mx-auto text-center pb-12 md:pb-14">
        <h2 class="h2 mb-4 font-red-hat-display">How it works</h2>
        <p class="text-xl text-gray-400">
          Three steps from a blank screen to a live presentation.
        </p>
      </div>

      <!-- Steps -->
      <div
        class="max-w-xs mx-auto sm:max-w-none md:max-w-2xl lg:max-w-none grid sm:grid-cols-3 gap-6"
        data-aos-id-howto
      >
        <!-- Step 1 -->
        <div
          class="flex flex-col items-center text-center"
          data-aos="fade-up"
          data-aos-anchor="[data-aos-id-howto]"
        >
          <div
            class="flex items-center justify-center w-12 h-12 rounded-full text-white font-red-hat-display font-black text-xl mb-4 bg-linear-to-tr from-teal-500 to-teal-400"
          >
            1
          </div>
          <div
            class="font-red-hat-display text-xl font-black tracking-tighter mb-2"
          >
            Install on your TV
          </div>
          <p class="text-gray-600 dark:text-gray-400">
            Open it in any browser, or grab the native app for Fire TV,
            Android, Windows
            <a
              href="/download"
              class="text-teal-500 hover:text-teal-400 underline"
            >
              and more.
            </a>
          </p>
        </div>

        <!-- Step 2 -->
        <div
          class="flex flex-col items-center text-center"
          data-aos="fade-up"
          data-aos-anchor="[data-aos-id-howto]"
          data-aos-delay="100"
        >
          <div
            class="flex items-center justify-center w-12 h-12 rounded-full text-white font-red-hat-display font-black text-xl mb-4 bg-linear-to-tr from-purple-500 to-purple-400"
          >
            2
          </div>
          <div
            class="font-red-hat-display text-xl font-black tracking-tighter mb-2"
          >
            Print a QR code
          </div>
          <p class="text-gray-600 dark:text-gray-400">
            Pin or display a QR code next to your screen. Guests can find it
            the moment they walk in.
          </p>
        </div>

        <!-- Step 3 -->
        <div
          class="flex flex-col items-center text-center"
          data-aos="fade-up"
          data-aos-anchor="[data-aos-id-howto]"
          data-aos-delay="200"
        >
          <div
            class="flex items-center justify-center w-12 h-12 rounded-full text-white font-red-hat-display font-black text-xl mb-4 bg-linear-to-tr from-indigo-500 to-indigo-400"
          >
            3
          </div>
          <div
            class="font-red-hat-display text-xl font-black tracking-tighter mb-2"
          >
            Guests scan & present
          </div>
          <p class="text-gray-600 dark:text-gray-400">
            They scan with any phone or laptop and instantly show whatever
            they want.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
