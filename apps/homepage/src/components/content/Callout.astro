---
interface Props {
  title?: string;
  class?: string;
}

const { title = "Before you start", class: className = "mb-12" } = Astro.props;
---

<div
  class:list={[
    "rounded-lg bg-teal-50 dark:bg-teal-500/10 border border-teal-200 dark:border-teal-500/30 p-5 flex gap-4 items-start",
    className,
  ]}
>
  <div
    class="shrink-0 w-10 h-10 rounded-full bg-teal-500/15 dark:bg-teal-500/20 flex items-center justify-center text-teal-600 dark:text-teal-400"
    aria-hidden="true"
  >
    <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
      <path
        d="M11 7h2v2h-2V7zm0 4h2v6h-2v-6zm1-9C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"
      ></path>
    </svg>
  </div>
  <div>
    <p class="font-semibold text-gray-900 dark:text-gray-100 mb-1">{title}</p>
    <div class="text-sm text-gray-600 dark:text-gray-300"><slot /></div>
  </div>
</div>
