---
---

<section>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div
      class="py-12 md:py-20 border-t border-transparent dark:border-gray-800"
    >
      <!-- Section header -->
      <div class="max-w-3xl mx-auto text-center pb-10 md:pb-14">
        <h2
          class="h2 mb-4 font-red-hat-display"
          data-aos="fade-up"
        >
          In production every week
        </h2>
        <p
          class="text-lg text-gray-600 dark:text-gray-400"
          data-aos="fade-up"
          data-aos-delay="100"
        >
          Not a demo. Live in front of real audiences, every week.
        </p>
      </div>

      <!-- Stat blocks -->
      <div
        class="max-w-sm mx-auto grid gap-6 sm:grid-cols-3 sm:max-w-none md:gap-8 items-stretch"
        data-aos-id-proof
      >
        <!-- Reliability: live every week, sector-neutral framing -->
        <div
          class="flex flex-col items-center text-center p-6 rounded-lg border border-gray-200 dark:border-gray-800"
          data-aos="fade-up"
          data-aos-anchor="[data-aos-id-proof]"
        >
          <div
            class="font-red-hat-display text-3xl md:text-4xl font-black tracking-tight mb-2 bg-clip-text text-transparent bg-gradient-to-r from-teal-400 to-purple-500"
          >
            Weekly
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Driving live presentations at UK venues, week in, week out.
          </p>
        </div>

        <!-- Audience scale -->
        <div
          class="flex flex-col items-center text-center p-6 rounded-lg border border-gray-200 dark:border-gray-800"
          data-aos="fade-up"
          data-aos-anchor="[data-aos-id-proof]"
          data-aos-delay="100"
        >
          <div
            class="font-red-hat-display text-3xl md:text-4xl font-black tracking-tight mb-2 bg-clip-text text-transparent bg-gradient-to-r from-teal-400 to-purple-500"
          >
            100&ndash;200
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Attendees per event, handled on a single setup.
          </p>
        </div>

        <!-- Development -->
        <div
          class="flex flex-col items-center text-center p-6 rounded-lg border border-gray-200 dark:border-gray-800"
          data-aos="fade-up"
          data-aos-anchor="[data-aos-id-proof]"
          data-aos-delay="200"
        >
          <div
            class="font-red-hat-display text-3xl md:text-4xl font-black tracking-tight mb-2 bg-clip-text text-transparent bg-gradient-to-r from-teal-400 to-purple-500"
          >
            1,400+
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Commits and counting. Active, ongoing development.
          </p>
        </div>
      </div>

      <!-- Open source / GitHub link -->
      <div
        class="mt-10 md:mt-12 flex justify-center"
        data-aos="fade-up"
      >
        <a
          class="inline-flex items-center gap-2 text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-teal-500 dark:hover:text-teal-400 transition-colors"
          href="https://github.com/Vija02/TheOpenPresenter"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            class="w-5 h-5 fill-current"
            viewBox="0 0 32 32"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path
              d="M16 8.2c-4.4 0-8 3.6-8 8 0 3.5 2.3 6.5 5.5 7.6.4.1.5-.2.5-.4V22c-2.2.5-2.7-1-2.7-1-.4-.9-.9-1.2-.9-1.2-.7-.5.1-.5.1-.5.8.1 1.2.8 1.2.8.7 1.3 1.9.9 2.3.7.1-.5.3-.9.5-1.1-1.8-.2-3.6-.9-3.6-4 0-.9.3-1.6.8-2.1-.1-.2-.4-1 .1-2.1 0 0 .7-.2 2.2.8.6-.2 1.3-.3 2-.3s1.4.1 2 .3c1.5-1 2.2-.8 2.2-.8.4 1.1.2 1.9.1 2.1.5.6.8 1.3.8 2.1 0 3.1-1.9 3.7-3.7 3.9.3.4.6.9.6 1.6v2.2c0 .2.1.5.6.4 3.2-1.1 5.5-4.1 5.5-7.6-.1-4.4-3.7-8-8.1-8z"
            ></path>
          </svg>
          Open source on GitHub &middot; AGPL 3.0
        </a>
      </div>
    </div>
  </div>
</section>
