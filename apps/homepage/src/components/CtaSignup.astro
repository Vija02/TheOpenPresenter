---
---

<!-- Sign-up CTA -->
<section class="bg-gray-100 dark:bg-gray-800">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div
      class="py-16 md:py-20 flex flex-col md:flex-row md:items-center md:justify-between gap-8 text-center md:text-left"
    >
      <h2
        class="h3 font-red-hat-display font-black leading-tight"
        data-aos="fade-up"
      >
        Ready to level up your screen?<br />
        <span
          class="inline-block pb-1 bg-clip-text text-transparent bg-gradient-to-r from-teal-400 to-purple-500"
        >
          Start for free today
        </span>
      </h2>
      <div
        class="flex flex-col sm:flex-row justify-center md:justify-end gap-3 shrink-0"
        data-aos="fade-up"
        data-aos-delay="100"
      >
        <a
          class="btn text-white bg-teal-500 hover:bg-teal-400"
          href="/register"
        >
          Sign up free
        </a>
        <a
          class="btn text-teal-500 bg-white hover:bg-gray-50 border border-teal-500 dark:bg-transparent dark:hover:bg-gray-700"
          href="#"
          data-init-demo-jump
        >
          View live demo
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  // "View live demo" link → scroll back to the hero
  document
    .querySelectorAll<HTMLAnchorElement>("[data-init-demo-jump]")
    .forEach((el) => {
      el.addEventListener("click", (e) => {
        e.preventDefault();
        document
          .querySelector("section")
          ?.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });
</script>
