---
import DefaultLayout from "../../../layouts/DefaultLayout.astro";
import PageIllustration from "../../../components/PageIllustration.astro";

const SPONSORSHIP_EMAIL = "sponsorship@theopenpresenter.com";
const MAILTO = `mailto:${SPONSORSHIP_EMAIL}?subject=${encodeURIComponent("Sponsorship application")}`;
---

<DefaultLayout
  title="Small-church sponsorship | TheOpenPresenter"
  description="The full TheOpenPresenter cloud plan, free for small churches. Read why we offer it, who qualifies, and how to apply."
>
  <!-- Page illustration -->
  <div
    class="relative max-w-6xl mx-auto h-0 pointer-events-none -z-1"
    aria-hidden="true"
  >
    <PageIllustration />
  </div>

  <section class="relative">
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
      <div class="pt-24 pb-12 md:pt-28 md:pb-20">
        <!-- Header -->
        <div class="max-w-3xl mx-auto text-center">
          <div
            class="inline-flex items-center text-sm font-semibold tracking-wide uppercase text-teal-500 mb-3"
            data-aos="fade-down"
          >
            For churches
          </div>
          <h1
            class="h2 font-red-hat-display mb-4"
            data-aos="fade-down"
            data-aos-delay="50"
          >
            The small-church sponsorship
          </h1>
          <p
            class="text-xl text-gray-600 dark:text-gray-400"
            data-aos="fade-down"
            data-aos-delay="150"
          >
            If your church is small, the full cloud plan is yours free, storage
            and AI credits included. It's always available and never taken away.
          </p>
        </div>

        <!-- Why -->
        <div
          class="max-w-3xl mx-auto mt-12 md:mt-16"
          data-aos="fade-up"
        >
          <h2 class="font-red-hat-display text-2xl font-black mb-3">
            Why we do this
          </h2>
          <div class="text-gray-600 dark:text-gray-400 space-y-4">
            <p>
              We believe small churches are key to fulfilling the Great
              Commission, and we want to remove the tech barrier that gets in the
              way. Multimedia shouldn't cost a small church the budget it doesn't
              have or the volunteer hours it can't spare.
            </p>
            <p>
              We started in a small church too, so we happily bear the cost. This
              sponsorship is our small part in helping your church do what
              matters most. There's never any obligation. If you're ever able to
              give back you're welcome to
              <a
                class="text-teal-600 dark:text-teal-400 hover:underline font-medium"
                href="/church/donate">donate</a
              >, but it's entirely optional.
            </p>
          </div>
        </div>

        <!-- Criteria + What's included -->
        <div class="max-w-3xl mx-auto mt-10 grid gap-6 md:grid-cols-2">
          <!-- Who it's for -->
          <div
            class="rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-800 p-8"
            data-aos="fade-right"
          >
            <h2 class="font-red-hat-display text-xl font-black mb-4">
              Who it's for
            </h2>
            <ul class="text-gray-600 dark:text-gray-400 space-y-3">
              <li class="flex items-start">
                <svg
                  class="w-3 h-3 fill-current text-teal-500 mr-2 mt-1.5 shrink-0"
                  viewBox="0 0 12 12"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>Churches with under 50 weekly attendance</span>
              </li>
              <li class="flex items-start">
                <svg
                  class="w-3 h-3 fill-current text-teal-500 mr-2 mt-1.5 shrink-0"
                  viewBox="0 0 12 12"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>A church, church plant or small ministry</span>
              </li>
            </ul>
          </div>

          <!-- What's included -->
          <div
            class="rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-800 p-8"
            data-aos="fade-left"
          >
            <h2 class="font-red-hat-display text-xl font-black mb-4">
              What's included
            </h2>
            <ul class="text-gray-600 dark:text-gray-400 space-y-3">
              <li class="flex items-start">
                <svg
                  class="w-3 h-3 fill-current text-teal-500 mr-2 mt-1.5 shrink-0"
                  viewBox="0 0 12 12"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>The full cloud plan, hosted for you</span>
              </li>
              <li class="flex items-start">
                <svg
                  class="w-3 h-3 fill-current text-teal-500 mr-2 mt-1.5 shrink-0"
                  viewBox="0 0 12 12"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>Storage included</span>
              </li>
              <li class="flex items-start">
                <svg
                  class="w-3 h-3 fill-current text-teal-500 mr-2 mt-1.5 shrink-0"
                  viewBox="0 0 12 12"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>AI credits included</span>
              </li>
              <li class="flex items-start">
                <svg
                  class="w-3 h-3 fill-current text-teal-500 mr-2 mt-1.5 shrink-0"
                  viewBox="0 0 12 12"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>Always free, never taken away</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- How to apply -->
        <div
          class="max-w-3xl mx-auto mt-6 rounded-2xl bg-teal-50 dark:bg-teal-500/10 border border-teal-200 dark:border-teal-500/30 p-8 text-center"
          data-aos="fade-up"
        >
          <h2 class="font-red-hat-display text-2xl font-black mb-2">
            How to apply
          </h2>
          <p class="text-gray-700 dark:text-gray-300 mb-6 max-w-xl mx-auto">
            Send us an email with the subject <strong>Sponsorship application</strong>
            and tell us a little about your church: <b>Who you are</b>, <b>roughly how many
            attend</b>, and <b>how you'd use TheOpenPresenter</b>. We'll get you set up.
          </p>
          <a class="btn text-white bg-teal-500 hover:bg-teal-400" href={MAILTO}>
            Email {SPONSORSHIP_EMAIL}
          </a>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-4">
            Or email us directly at
            <a
              class="text-teal-600 dark:text-teal-400 hover:underline font-medium"
              href={MAILTO}>{SPONSORSHIP_EMAIL}</a
            >
            with the subject "Sponsorship application".
          </p>
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>
