---
import DefaultLayout from "../../layouts/DefaultLayout.astro";
import PageIllustration from "../../components/PageIllustration.astro";
---

<DefaultLayout title="Download | TheOpenPresenter">
  <!-- Page illustration -->
  <div
    class="relative max-w-6xl mx-auto h-0 pointer-events-none -z-1"
    aria-hidden="true"
  >
    <PageIllustration />
  </div>
  <section class="relative">
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
      <div class="pt-32 pb-12 md:pt-40 md:pb-20">
        <!-- Page header -->
        <div class="max-w-3xl mb-10">
          <h1 class="h1 font-red-hat-display mb-4" data-aos="fade-down">
            Download
          </h1>
          <p
            class="text-xl text-gray-600 dark:text-gray-400"
            data-aos="fade-down"
            data-aos-delay="150"
          >
            Get TheOpenPresenter on your favorite platform.
          </p>
        </div>

        <!-- Web availability note -->
        <div
          class="max-w-3xl rounded-lg bg-teal-50 dark:bg-teal-500/10 border border-teal-200 dark:border-teal-500/30 p-5 mb-10 flex gap-4 items-start"
          data-aos="fade-up"
        >
          <div
            class="flex-shrink-0 w-10 h-10 rounded-full bg-teal-500/15 dark:bg-teal-500/20 flex items-center justify-center text-teal-600 dark:text-teal-400"
            aria-hidden="true"
          >
            <svg
              class="w-5 h-5 fill-current"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"
              ></path>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-gray-900 dark:text-gray-100 mb-1">
              Everything works on the web
            </p>
            <p class="text-sm text-gray-600 dark:text-gray-400">
              TheOpenPresenter is fully available on the <a
                class="text-teal-600 dark:text-teal-400 hover:underline font-medium"
                href="/login">web</a
              >. Every feature works right in your browser, no download
              required. The apps below are optional and offer a smoother, more
              integrated experience on supported devices.
            </p>
          </div>
        </div>

        <!-- Questionnaire -->
        <div
          id="download-questionnaire"
          class="max-w-3xl rounded-lg border border-gray-200 dark:border-gray-800 p-8 mb-10"
          data-aos="fade-up"
        >
          <h2 class="h3 font-red-hat-display mb-2">
            Find the right app for you
          </h2>
          <p class="text-gray-600 dark:text-gray-400 mb-8">
            Answer a couple of quick questions and we'll point you to the right
            app.
          </p>

          <!-- Step: start -->
          <div data-step="start">
            <p class="font-medium text-gray-900 dark:text-gray-100 mb-4">
              1. What are you using TheOpenPresenter for?
            </p>
            <div class="grid gap-4 sm:grid-cols-2">
              <button
                type="button"
                class="q-option group cursor-pointer text-left rounded-lg border border-gray-200 dark:border-gray-700 p-6 sm:p-7 hover:border-teal-500 dark:hover:border-teal-400 transition duration-150 ease-in-out"
                data-goto="church"
              >
                <span
                  class="block text-lg font-semibold text-gray-900 dark:text-gray-100 group-hover:text-teal-600 dark:group-hover:text-teal-400"
                  >A church</span
                >
                <span class="block text-base text-gray-500 dark:text-gray-400 mt-1.5"
                  >Worship services, sermons, lyrics</span
                >
              </button>
              <button
                type="button"
                class="q-option group cursor-pointer text-left rounded-lg border border-gray-200 dark:border-gray-700 p-6 sm:p-7 hover:border-teal-500 dark:hover:border-teal-400 transition duration-150 ease-in-out"
                data-goto="commercial"
              >
                <span
                  class="block text-lg font-semibold text-gray-900 dark:text-gray-100 group-hover:text-teal-600 dark:group-hover:text-teal-400"
                  >Commercial / business</span
                >
                <span class="block text-base text-gray-500 dark:text-gray-400 mt-1.5"
                  >Venues, offices, meeting spaces</span
                >
              </button>
            </div>
          </div>

          <!-- Step: church -->
          <div
            data-step="church"
            class="mt-8 pt-8 border-t border-gray-100 dark:border-gray-800"
            hidden
          >
            <p class="font-medium text-gray-900 dark:text-gray-100 mb-4">
              2. How do you want to run it?
            </p>
            <div class="grid gap-4 sm:grid-cols-2">
              <button
                type="button"
                class="q-option group cursor-pointer text-left rounded-lg border border-gray-200 dark:border-gray-700 p-6 sm:p-7 hover:border-teal-500 dark:hover:border-teal-400 transition duration-150 ease-in-out"
                data-result="studio"
              >
                <span
                  class="block text-lg font-semibold text-gray-900 dark:text-gray-100 group-hover:text-teal-600 dark:group-hover:text-teal-400"
                  >Replace my current software</span
                >
                <span class="block text-base text-gray-500 dark:text-gray-400 mt-1.5"
                  >Move off ProPresenter or similar, run it on my own
                  machine</span
                >
              </button>
              <button
                type="button"
                class="q-option group cursor-pointer text-left rounded-lg border border-gray-200 dark:border-gray-700 p-6 sm:p-7 hover:border-teal-500 dark:hover:border-teal-400 transition duration-150 ease-in-out"
                data-result="kiosk"
              >
                <span
                  class="block text-lg font-semibold text-gray-900 dark:text-gray-100 group-hover:text-teal-600 dark:group-hover:text-teal-400"
                  >Fully in the cloud</span
                >
                <span class="block text-base text-gray-500 dark:text-gray-400 mt-1.5"
                  >Control from the web, just need a display device</span
                >
              </button>
            </div>
          </div>

          <!-- Step: commercial -->
          <div
            data-step="commercial"
            class="mt-8 pt-8 border-t border-gray-100 dark:border-gray-800"
            hidden
          >
            <p class="font-medium text-gray-900 dark:text-gray-100 mb-4">
              2. Where will you be running it?
            </p>
            <div class="grid gap-4 sm:grid-cols-2">
              <button
                type="button"
                class="q-option group cursor-pointer text-left rounded-lg border border-gray-200 dark:border-gray-700 p-6 sm:p-7 hover:border-teal-500 dark:hover:border-teal-400 transition duration-150 ease-in-out"
                data-result="studio"
              >
                <span
                  class="block text-lg font-semibold text-gray-900 dark:text-gray-100 group-hover:text-teal-600 dark:group-hover:text-teal-400"
                  >An event venue</span
                >
                <span class="block text-base text-gray-500 dark:text-gray-400 mt-1.5"
                  >Live events, a dedicated operator running the show</span
                >
              </button>
              <button
                type="button"
                class="q-option group cursor-pointer text-left rounded-lg border border-gray-200 dark:border-gray-700 p-6 sm:p-7 hover:border-teal-500 dark:hover:border-teal-400 transition duration-150 ease-in-out"
                data-result="kiosk"
              >
                <span
                  class="block text-lg font-semibold text-gray-900 dark:text-gray-100 group-hover:text-teal-600 dark:group-hover:text-teal-400"
                  >A meeting room</span
                >
                <span class="block text-base text-gray-500 dark:text-gray-400 mt-1.5"
                  >Always-on display, controlled remotely from the web</span
                >
              </button>
            </div>
          </div>

          <!-- Result: studio -->
          <div
            data-result-panel="studio"
            class="mt-8 pt-8 border-t border-gray-100 dark:border-gray-800"
            hidden
          >
            <p
              class="text-xs font-semibold uppercase tracking-wide text-teal-600 dark:text-teal-400 mb-2"
            >
              We recommend
            </p>
            <h3 class="h4 font-red-hat-display mb-2">TheOpenPresenter Studio</h3>
            <p class="text-gray-600 dark:text-gray-400 mb-6">
              Runs the full suite natively on your computer, self-contained on a
              single machine. The best fit for replacing your current presentation
              software or running a live event.
            </p>
            <div class="flex flex-wrap gap-3">
              <button
                type="button"
                class="q-scroll cursor-pointer inline-flex items-center justify-center gap-2 px-6 py-3 rounded-md bg-gray-900 hover:bg-gray-700 text-white dark:bg-white dark:text-gray-900 dark:hover:bg-gray-200 font-medium shadow-sm hover:shadow-lg transition duration-150 ease-in-out"
                data-scroll="#studio"
              >
                Get Studio
              </button>
              <button
                type="button"
                class="q-restart cursor-pointer inline-flex items-center justify-center gap-2 px-6 py-3 rounded-md border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:border-teal-500 dark:hover:border-teal-400 font-medium transition duration-150 ease-in-out"
              >
                Start over
              </button>
            </div>
          </div>

          <!-- Result: kiosk -->
          <div
            data-result-panel="kiosk"
            class="mt-8 pt-8 border-t border-gray-100 dark:border-gray-800"
            hidden
          >
            <p
              class="text-xs font-semibold uppercase tracking-wide text-teal-600 dark:text-teal-400 mb-2"
            >
              We recommend
            </p>
            <h3 class="h4 font-red-hat-display mb-2">Kiosk App</h3>
            <p class="text-gray-600 dark:text-gray-400 mb-6">
              Turn any TV, monitor, or computer into an always-on display. You
              control everything from the web and the device just shows your
              content, perfect for a fully cloud-based setup.
            </p>
            <div class="flex flex-wrap gap-3">
              <button
                type="button"
                class="q-scroll cursor-pointer inline-flex items-center justify-center gap-2 px-6 py-3 rounded-md bg-gray-900 hover:bg-gray-700 text-white dark:bg-white dark:text-gray-900 dark:hover:bg-gray-200 font-medium shadow-sm hover:shadow-lg transition duration-150 ease-in-out"
                data-scroll="#kiosk"
              >
                Get the Kiosk App
              </button>
              <button
                type="button"
                class="q-restart cursor-pointer inline-flex items-center justify-center gap-2 px-6 py-3 rounded-md border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:border-teal-500 dark:hover:border-teal-400 font-medium transition duration-150 ease-in-out"
              >
                Start over
              </button>
            </div>
          </div>
        </div>

        <!-- Choose manually -->
        <div id="choose" class="mt-2 scroll-mt-24" data-aos="fade-up">
          <h2 class="h4 font-red-hat-display mb-2">Or choose manually</h2>
          <p class="text-gray-600 dark:text-gray-400 mb-6">
            Prefer to decide yourself? Expand an app to see all its downloads.
          </p>

          <!-- Download options -->
          <div class="flex flex-col gap-6">
            <!-- Kiosk App (TV + Desktop) -->
            <details
              id="kiosk"
              class="group relative z-20 rounded-lg border border-gray-200 dark:border-gray-800 scroll-mt-24"
            >
              <summary
                class="flex items-start justify-between gap-4 p-8 cursor-pointer list-none [&::-webkit-details-marker]:hidden"
              >
                <span class="block">
                  <span class="block h3 font-red-hat-display mb-2">Kiosk App</span
                  >
                  <span class="block text-gray-600 dark:text-gray-400 max-w-3xl">
                    Turn any TV, monitor, or computer into a permanent, always-on
                    display for TheOpenPresenter. Pair once via QR, pick which
                    screen, and the device boots straight into a fullscreen render
                    every time.
                  </span>
                </span>
                <svg
                  class="w-5 h-5 mt-1 flex-shrink-0 fill-current text-gray-400 transition-transform duration-150 group-open:rotate-180"
                  viewBox="0 0 20 20"
                  xmlns="http://www.w3.org/2000/svg"
                  aria-hidden="true"
                >
                  <path
                    d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.17l3.71-3.94a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06z"
                  ></path>
                </svg>
              </summary>
              <div class="px-8 pb-8">

            <!-- TV platforms -->
            <h3
              class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-4"
            >
              On a TV
            </h3>
            <div class="grid gap-8 md:grid-cols-2 mb-10">
              <!-- Fire TV -->
              <div>
                <h4 class="font-medium text-lg mb-3">Fire TV</h4>
                <a
                  class="inline-block transition duration-150 ease-in-out hover:opacity-80"
                  href="https://www.amazon.com/dp/B0GZG5HFSY"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Get TheOpenPresenter on Amazon Appstore"
                  data-download="kiosk"
                  data-platform="firetv"
                  data-variant="amazon-appstore"
                >
                  <img
                    src="/images/amazon-appstore-badge-english-black.png"
                    alt="Available at Amazon Appstore"
                    class="h-12 w-auto"
                  />
                </a>
                <p
                  class="text-sm font-medium text-gray-700 dark:text-gray-300 mt-4 mb-1"
                >
                  Compatible devices
                </p>
                <ul
                  class="text-sm text-gray-600 dark:text-gray-400 list-disc list-inside space-y-0.5"
                >
                  <li>Fire TV Stick (2nd gen and newer)</li>
                  <li>Fire TV Stick 4K and 4K Max</li>
                  <li>Fire TV Cube (all generations)</li>
                  <li>Fire TV smart TVs and Fire TV Edition TVs</li>
                </ul>
              </div>

              <!-- Android TV / Google TV -->
              <div>
                <h4 class="font-medium text-lg mb-3">Android TV / Google TV</h4>
                <a
                  class="inline-block transition duration-150 ease-in-out hover:opacity-80"
                  href="https://play.google.com/store/apps/details?id=com.theopenpresenter.tv"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Get TheOpenPresenter on Google Play"
                  data-download="kiosk"
                  data-platform="androidtv"
                  data-variant="google-play"
                >
                  <img
                    src="/svg/googleplay.svg"
                    alt="Get it on Google Play"
                    class="h-12 w-auto"
                  />
                </a>
                <p
                  class="text-sm font-medium text-gray-700 dark:text-gray-300 mt-4 mb-1"
                >
                  Compatible devices
                </p>
                <ul
                  class="text-sm text-gray-600 dark:text-gray-400 list-disc list-inside space-y-0.5"
                >
                  <li>Chromecast with Google TV</li>
                  <li>Google TV Streamer</li>
                  <li>Android TV and Google TV smart TVs</li>
                  <li>NVIDIA Shield TV</li>
                  <li>Other Android TV devices</li>
                </ul>
              </div>
            </div>

            <!-- Desktop platforms -->
            <h3
              class="text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400 mb-4"
            >
              On a computer
            </h3>
            <div class="grid gap-8 md:grid-cols-2">
              <!-- Windows -->
              <div>
                <h4 class="font-medium text-lg mb-3">Windows</h4>
                <a
                  class="inline-flex items-center justify-center gap-3 px-6 py-3 rounded-md bg-gray-900 hover:bg-gray-700 text-white dark:bg-white dark:text-gray-900 dark:hover:bg-gray-200 font-medium shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition duration-150 ease-in-out"
                  href="https://github.com/Vija02/TheOpenPresenter/releases/download/desktop-screen-nightly/desktop-screen-windows-x86_64-setup.exe"
                  data-download="kiosk"
                  data-platform="windows"
                  data-variant="exe"
                >
                  <svg
                    class="w-6 h-6 fill-current"
                    viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg"
                    aria-hidden="true"
                  >
                    <path
                      d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-13.051-1.851"
                    ></path>
                  </svg>
                  <span
                    class="flex flex-col items-start leading-tight text-left"
                  >
                    <span class="text-xs opacity-80">Download for</span>
                    <span class="text-base font-semibold">Windows (64-bit)</span
                    >
                  </span>
                </a>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-3">
                  Or get the <a
                    class="text-teal-500 hover:underline"
                    href="https://github.com/Vija02/TheOpenPresenter/releases/download/desktop-screen-nightly/desktop-screen-windows-x86_64.msi"
                    data-download="kiosk"
                    data-platform="windows"
                    data-variant="msi"
                    >.msi installer</a
                  > for enterprise deployment.
                </p>
              </div>

              <!-- macOS -->
              <div>
                <h4 class="font-medium text-lg mb-3">macOS</h4>
                <a
                  class="inline-flex items-center justify-center gap-3 px-6 py-3 rounded-md bg-gray-900 hover:bg-gray-700 text-white dark:bg-white dark:text-gray-900 dark:hover:bg-gray-200 font-medium shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition duration-150 ease-in-out"
                  href="https://github.com/Vija02/TheOpenPresenter/releases/download/desktop-screen-nightly/desktop-screen-macos-aarch64.dmg"
                  data-download="kiosk"
                  data-platform="macos"
                  data-variant="dmg-aarch64"
                >
                  <svg
                    class="w-6 h-6 fill-current"
                    viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg"
                    aria-hidden="true"
                  >
                    <path
                      d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.07-.5-2.05-.51-3.18 0-1.41.62-2.16.44-3.02-.4C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"
                    ></path>
                  </svg>
                  <span
                    class="flex flex-col items-start leading-tight text-left"
                  >
                    <span class="text-xs opacity-80">Download for</span>
                    <span class="text-base font-semibold"
                      >macOS (Apple Silicon)</span
                    >
                  </span>
                </a>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-3">
                  On an Intel Mac? Get the <a
                    class="text-teal-500 hover:underline"
                    href="https://github.com/Vija02/TheOpenPresenter/releases/download/desktop-screen-nightly/desktop-screen-macos-x86_64.dmg"
                    data-download="kiosk"
                    data-platform="macos"
                    data-variant="dmg-x86_64"
                    >Intel build</a
                  > instead.
                </p>
              </div>

              <!-- Linux -->
              <div>
                <h4 class="font-medium text-lg mb-3">Linux</h4>
                <details
                  data-autoclose
                  class="group relative inline-block text-left"
                >
                  <summary
                    class="inline-flex items-center justify-center gap-3 px-6 py-3 rounded-md bg-gray-900 hover:bg-gray-700 text-white dark:bg-white dark:text-gray-900 dark:hover:bg-gray-200 font-medium shadow-sm hover:shadow-lg transition duration-150 ease-in-out cursor-pointer list-none [&::-webkit-details-marker]:hidden"
                  >
                    <svg
                      class="w-6 h-6 fill-current"
                      viewBox="0 0 24 24"
                      xmlns="http://www.w3.org/2000/svg"
                      aria-hidden="true"
                    >
                      <path
                        d="M17.61.455a3.41 3.41 0 0 0-3.41 3.41 3.41 3.41 0 0 0 3.41 3.41 3.41 3.41 0 0 0 3.41-3.41 3.41 3.41 0 0 0-3.41-3.41zM12.92.8C8.923.777 5.137 2.941 3.148 6.451a4.5 4.5 0 0 1 .26-.007 4.92 4.92 0 0 1 2.585.737A8.316 8.316 0 0 1 12.688 3.6 4.944 4.944 0 0 1 13.723.834 11.008 11.008 0 0 0 12.92.8zm9.226 4.994a4.915 4.915 0 0 1-1.918 2.246 8.36 8.36 0 0 1-.273 8.303 4.89 4.89 0 0 1 1.632 2.54 11.156 11.156 0 0 0 .559-13.089zM3.41 7.932A3.41 3.41 0 0 0 0 11.342a3.41 3.41 0 0 0 3.41 3.409 3.41 3.41 0 0 0 3.41-3.41 3.41 3.41 0 0 0-3.41-3.41zm2.027 7.866a4.908 4.908 0 0 1-2.915.358 11.1 11.1 0 0 0 7.991 6.698 11.234 11.234 0 0 0 2.422.249 4.879 4.879 0 0 1-.999-2.85 8.484 8.484 0 0 1-.836-.136 8.304 8.304 0 0 1-5.663-4.32zm11.405.928a3.41 3.41 0 0 0-3.41 3.41 3.41 3.41 0 0 0 3.41 3.41 3.41 3.41 0 0 0 3.41-3.41 3.41 3.41 0 0 0-3.41-3.41z"
                      ></path>
                    </svg>
                    <span
                      class="flex flex-col items-start leading-tight text-left"
                    >
                      <span class="text-xs opacity-80">Download for</span>
                      <span class="text-base font-semibold">Linux</span>
                    </span>
                    <svg
                      class="w-4 h-4 fill-current opacity-70 transition-transform duration-150 group-open:rotate-180"
                      viewBox="0 0 20 20"
                      xmlns="http://www.w3.org/2000/svg"
                      aria-hidden="true"
                    >
                      <path
                        d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.17l3.71-3.94a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06z"
                      ></path>
                    </svg>
                  </summary>
                  <div
                    class="absolute left-0 z-30 mt-2 w-72 origin-top-left rounded-md border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 shadow-lg overflow-hidden"
                  >
                    <a
                      class="flex items-baseline justify-between gap-4 px-4 py-3 hover:bg-gray-50 dark:hover:bg-gray-700/50"
                      href="https://github.com/Vija02/TheOpenPresenter/releases/download/electron-screen-nightly/TheOpenPresenterScreen-x86_64.AppImage"
                      data-download="kiosk"
                      data-platform="linux"
                      data-variant="appimage"
                    >
                      <span class="font-medium text-gray-900 dark:text-gray-100"
                        >AppImage</span
                      >
                      <span class="text-xs text-gray-500 dark:text-gray-400"
                        >Any distro</span
                      >
                    </a>
                    <a
                      class="flex items-baseline justify-between gap-4 px-4 py-3 border-t border-gray-100 dark:border-gray-700/60 hover:bg-gray-50 dark:hover:bg-gray-700/50"
                      href="https://github.com/Vija02/TheOpenPresenter/releases/download/electron-screen-nightly/electron-screen-amd64.deb"
                      data-download="kiosk"
                      data-platform="linux"
                      data-variant="deb"
                    >
