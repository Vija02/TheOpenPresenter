---
import DefaultLayout from "../../layouts/DefaultLayout.astro";
import PageIllustration from "../../components/PageIllustration.astro";
---

<DefaultLayout title="Download | TheOpenPresenter">
  <!-- Page illustration -->
  <div
    class="relative max-w-6xl mx-auto h-0 pointer-events-none -z-1"
    aria-hidden="true"
  >
    <PageIllustration />
  </div>
  <section class="relative">
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
      <div class="pt-32 pb-12 md:pt-40 md:pb-20">
        <!-- Page header -->
        <div class="max-w-3xl">
          <h1 class="h1 font-red-hat-display mb-4" data-aos="fade-down">
            Download
          </h1>
          <p
            class="text-xl text-gray-600 dark:text-gray-400"
            data-aos="fade-down"
            data-aos-delay="150"
          >
            Get TheOpenPresenter on your favorite platform.
          </p>
        </div>

        <!-- Web availability note -->
        <div
          class="max-w-3xl rounded-lg bg-teal-50 dark:bg-teal-500/10 border border-teal-200 dark:border-teal-500/30 p-5 mb-10 flex gap-4 items-start"
          data-aos="fade-up"
        >
          <div
            class="flex-shrink-0 w-10 h-10 rounded-full bg-teal-500/15 dark:bg-teal-500/20 flex items-center justify-center text-teal-600 dark:text-teal-400"
            aria-hidden="true"
          >
            <svg
              class="w-5 h-5 fill-current"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"
              ></path>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-gray-900 dark:text-gray-100 mb-1">
              Everything works on the web
            </p>
            <p class="text-sm text-gray-600 dark:text-gray-400">
              TheOpenPresenter is fully available on the <a
                class="text-teal-600 dark:text-teal-400 hover:underline font-medium"
                href="/login">web</a
              >. Every feature works right in your browser, no download
              required. The apps below are optional and offer a smoother,
              more integrated experience on supported devices.
            </p>
          </div>
        </div>

        <!-- Download options -->
        <div class="flex flex-col gap-8">
          <!-- TV App -->
          <div
            class="rounded-lg border border-gray-200 dark:border-gray-800 p-8"
            data-aos="fade-up"
          >
            <h2 class="h3 font-red-hat-display mb-2">TV App</h2>
            <p class="text-gray-600 dark:text-gray-400 mb-8">
              Install on a supported TV device to turn any TV or monitor into a
              permanent, always-on display for TheOpenPresenter. Perfect
              for keeping the presenter view up on a dedicated screen.
            </p>

            <!-- Platforms -->
            <div class="grid gap-8 md:grid-cols-2">
              <!-- Fire TV -->
              <div>
                <h3 class="font-medium text-lg mb-3">Fire TV</h3>
                <a
                  class="inline-block transition duration-150 ease-in-out hover:opacity-80"
                  href="https://www.amazon.com/dp/B0GZG5HFSY"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Get TheOpenPresenter on Amazon Appstore"
                >
                  <img
                    src="/images/amazon-appstore-badge-english-black.png"
                    alt="Available at Amazon Appstore"
                    class="h-12 w-auto"
                  />
                </a>
                <p
                  class="text-sm font-medium text-gray-700 dark:text-gray-300 mt-4 mb-1"
                >
                  Compatible devices
                </p>
                <ul
                  class="text-sm text-gray-600 dark:text-gray-400 list-disc list-inside space-y-0.5"
                >
                  <li>Fire TV Stick (2nd gen and newer)</li>
                  <li>Fire TV Stick HD (new generation)</li>
                  <li>Fire TV Stick 4K, 4K Max, and 4K Select</li>
                  <li>Fire TV Cube (all generations)</li>
                  <li>Fire TV smart TVs and Fire TV Edition TVs</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Local App -->
          <div
            class="rounded-lg border border-gray-200 dark:border-gray-800 p-8"
            data-aos="fade-up"
            data-aos-delay="150"
          >
            <h2 class="h3 font-red-hat-display mb-2">Local App</h2>
            <p class="text-gray-600 dark:text-gray-400 mb-8">
              Run TheOpenPresenter natively on your computer. Useful if you want
              everything self-contained on a single machine without relying on
              the web.
            </p>

            <!-- Platforms -->
            <div class="grid gap-8 md:grid-cols-2">
              <!-- Windows -->
              <div>
                <h3 class="font-medium text-lg mb-3">Windows</h3>
                <a
                  class="inline-flex items-center justify-center gap-3 px-6 py-3 rounded-md bg-teal-500 hover:bg-teal-400 text-white font-medium shadow-sm transition duration-150 ease-in-out"
                  href="https://github.com/Vija02/TheOpenPresenter/releases/download/nightly/TheOpenPresenter_0.1.0_x64-setup.exe"
                >
                  <svg
                    class="w-6 h-6 fill-current"
                    viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg"
                    aria-hidden="true"
                  >
                    <path
                      d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-13.051-1.851"
                    ></path>
                  </svg>
                  <span class="flex flex-col items-start leading-tight text-left">
                    <span class="text-xs opacity-80">Download for</span>
                    <span class="text-base font-semibold">Windows (64-bit)</span>
                  </span>
                </a>
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-3">
                  Or get the <a
                    class="text-teal-500 hover:underline"
                    href="https://github.com/Vija02/TheOpenPresenter/releases/download/nightly/TheOpenPresenter_0.1.0_x64_en-US.msi"
                    >.msi installer</a
                  > for enterprise deployment.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>
