---
import DefaultLayout from "../../layouts/DefaultLayout.astro";
import PageIllustration from "../../components/PageIllustration.astro";
import CtaSignup from "@/components/CtaSignup.astro";
---

<DefaultLayout
  title="Pricing | TheOpenPresenter"
  description="Open source presentation software. Start free on our cloud, own a room for life with one payment, or self-host it yourself. No forced subscription."
>
  <!-- Page illustration -->
  <div
    class="relative max-w-6xl mx-auto h-0 pointer-events-none -z-1"
    aria-hidden="true"
  >
    <PageIllustration />
  </div>

  <section class="relative">
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
      <div class="pt-32 pb-12 md:pt-40 md:pb-16">
        <!-- Page header -->
        <div class="max-w-3xl mx-auto text-center">
          <h1 class="h1 font-red-hat-display mb-4" data-aos="fade-down">
            Own your room in the cloud.
          </h1>
          <p
            class="text-xl text-gray-600 dark:text-gray-400"
            data-aos="fade-down"
            data-aos-delay="150"
          >
            Start free on our cloud, buy a room for life when you need more,
            or self-host the open source app on your own hardware. No forced
            subscription, no lock-in.
          </p>
        </div>

        <!-- Pricing cards -->
        <div class="max-w-6xl mx-auto mt-12 md:mt-16 grid gap-6 md:grid-cols-3">
          <!-- Free tier -->
          <div
            class="flex flex-col rounded-lg border border-gray-200 dark:border-gray-800 p-6 bg-white dark:bg-gray-900"
            data-aos="fade-up"
          >
            <div class="mb-6">
              <h2 class="h3 font-red-hat-display mb-1">Free</h2>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                For signage, small rooms, and anyone trying us out.
              </p>
            </div>
            <div class="mb-1">
              <span class="text-4xl font-extrabold font-red-hat-display">
                &pound;0
              </span>
              <span class="text-gray-600 dark:text-gray-400 ml-1">
                forever
              </span>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">
              no time limit &middot; no card needed
            </p>
            <a
              class="btn-sm text-white bg-gray-700 hover:bg-gray-800 dark:bg-gray-700 dark:hover:bg-gray-600 w-full mb-6 justify-center"
              href="/register"
            >
              Sign up free
            </a>
            <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-2">
              <li class="flex items-start">
                <svg
                  class="w-3 h-3 mt-1.5 mr-2 shrink-0 fill-current text-teal-500"
                  viewBox="0 0 12 12"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>Up to 5 connected displays</span>
              </li>
              <li class="flex items-start">
                <svg
                  class="w-3 h-3 mt-1.5 mr-2 shrink-0 fill-current text-teal-500"
                  viewBox="0 0 12 12"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>1 GB storage</span>
              </li>
              <li class="flex items-start">
                <svg
                  class="w-3 h-3 mt-1.5 mr-2 shrink-0 fill-current text-teal-500"
                  viewBox="0 0 12 12"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>All official plugins</span>
              </li>
              <li class="flex items-start">
                <svg
                  class="w-3 h-3 mt-1.5 mr-2 shrink-0 fill-current text-teal-500"
                  viewBox="0 0 12 12"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>Multi-controller, real-time collaboration</span>
              </li>
              <li class="flex items-start">
                <svg
                  class="w-3 h-3 mt-1.5 mr-2 shrink-0 fill-current text-teal-500"
                  viewBox="0 0 12 12"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>Community support</span>
              </li>
            </ul>
          </div>

          <!-- Lifetime tier (recommended) -->
          <div
            class="relative flex flex-col rounded-lg border-2 border-teal-500 p-6 bg-white dark:bg-gray-900 shadow-lg"
            data-aos="fade-up"
            data-aos-delay="150"
          >
            <span
              class="absolute -top-3 left-1/2 -translate-x-1/2 bg-teal-500 text-white text-xs font-semibold px-3 py-1 rounded-full uppercase tracking-wide"
            >
              Most popular
            </span>
            <div class="mb-6">
              <h2 class="h3 font-red-hat-display mb-1">Lifetime</h2>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                For venues with paying clients and guest presenters.
              </p>
            </div>
            <div class="mb-1">
              <span class="text-4xl font-extrabold font-red-hat-display">
                &pound;990
              </span>
              <span class="text-gray-600 dark:text-gray-400 ml-1">
                one-time
              </span>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">
              per room &middot; yours for life, no subscription
            </p>
            <a
              class="btn-sm text-white bg-teal-500 hover:bg-teal-400 w-full mb-4 justify-center"
              href="/register?plan=lifetime"
            >
              Buy a room
            </a>
            <!-- Monthly alternative -->
            <div
              class="rounded-md border border-gray-200 dark:border-gray-700 p-3 mb-3 text-sm text-gray-600 dark:text-gray-400"
            >
              <span class="font-semibold text-gray-900 dark:text-gray-100"
                >Prefer monthly?</span
              >
              &pound;79/mo per room, no lock-in. Cancel any time, or buy the
              Lifetime licence whenever you're ready.
            </div>
            <p class="text-xs text-gray-500 dark:text-gray-400 mb-6">
              Fitting out several rooms?
              <span class="font-medium text-gray-700 dark:text-gray-300"
                >&pound;790 each for 2&ndash;4, &pound;590 each for 5+.</span
              >
            </p>
            <p
              class="text-xs uppercase tracking-wide font-semibold text-gray-500 dark:text-gray-400 mb-3"
            >
              Everything in Free, plus
            </p>
            <ul class="text-sm text-gray-700 dark:text-gray-300 space-y-2">
              <li class="flex items-start">
                <svg
                  class="w-3 h-3 mt-1.5 mr-2 shrink-0 fill-current text-teal-500"
                  viewBox="0 0 12 12"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>
                  <strong>Guest portal.</strong> Send a link, your guest uploads
                  and presents from their own device
                </span>
              </li>
              <li class="flex items-start">
                <svg
                  class="w-3 h-3 mt-1.5 mr-2 shrink-0 fill-current text-teal-500"
                  viewBox="0 0 12 12"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>Custom branding on the guest portal</span>
              </li>
              <li class="flex items-start">
                <svg
                  class="w-3 h-3 mt-1.5 mr-2 shrink-0 fill-current text-teal-500"
                  viewBox="0 0 12 12"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>
                  Drive main screen, confidence monitor, and signage from one
                  synchronised show
                </span>
              </li>
              <li class="flex items-start">
                <svg
                  class="w-3 h-3 mt-1.5 mr-2 shrink-0 fill-current text-teal-500"
                  viewBox="0 0 12 12"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>Multi-room management dashboard</span>
              </li>
              <li class="flex items-start">
                <svg
                  class="w-3 h-3 mt-1.5 mr-2 shrink-0 fill-current text-teal-500"
                  viewBox="0 0 12 12"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>50 GB storage per room</span>
              </li>
              <li class="flex items-start">
                <svg
                  class="w-3 h-3 mt-1.5 mr-2 shrink-0 fill-current text-teal-500"
                  viewBox="0 0 12 12"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>Bug fixes and security updates included, always</span>
              </li>
              <li class="flex items-start">
                <svg
                  class="w-3 h-3 mt-1.5 mr-2 shrink-0 fill-current text-teal-500"
                  viewBox="0 0 12 12"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>1 year of AI tools and priority support included</span>
              </li>
            </ul>
          </div>

          <!-- Self-host tier -->
          <div
            class="flex flex-col rounded-lg border border-gray-200 dark:border-gray-800 p-6 bg-white dark:bg-gray-900"
            data-aos="fade-up"
            data-aos-delay="300"
          >
            <div class="mb-6">
              <h2 class="h3 font-red-hat-display mb-1">Self-host</h2>
              <p class="text-sm text-gray-600 dark:text-gray-400">
                Keep everything on your own hardware and network.
              </p>
            </div>
            <div class="mb-1">
              <span class="text-3xl font-extrabold font-red-hat-display">
                Open-source
              </span>
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">
              run it free on your own server &middot; your data never leaves your network
            </p>
            <a
              class="btn-sm text-white bg-gray-700 hover:bg-gray-800 dark:bg-gray-700 dark:hover:bg-gray-600 w-full mb-6 justify-center"
              href="https://github.com/vija02/theopenpresenter"
            >
              Get the source
            </a>
            <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-2">
              <li class="flex items-start">
                <svg
                  class="w-3 h-3 mt-1.5 mr-2 shrink-0 fill-current text-teal-500"
                  viewBox="0 0 12 12"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>Full app, run on your own hardware</span>
              </li>
              <li class="flex items-start">
                <svg
                  class="w-3 h-3 mt-1.5 mr-2 shrink-0 fill-current text-teal-500"
                  viewBox="0 0 12 12"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>Your data stays entirely on your network</span>
              </li>
              <li class="flex items-start">
                <svg
                  class="w-3 h-3 mt-1.5 mr-2 shrink-0 fill-current text-teal-500"
                  viewBox="0 0 12 12"
                  xmlns="http://www.w3.org/2000/svg"
                >
                  <path
                    d="M10.28 2.28L3.989 8.575 1.695 6.28A1 1 0 00.28 7.695l3 3a1 1 0 001.414 0l7-7A1 1 0 0010.28 2.28z"
                  ></path>
                </svg>
                <span>No per-room limits, run what your hardware allows</span>
              </li>
              <li class="flex items-start text-gray-500 dark:text-gray-500">
                <span class="w-3 mr-2 shrink-0 text-center">&middot;</span>
                <span>Community support &middot; you handle updates and backups</span>
              </li>
            </ul>
            <div class="mt-4 text-xs text-gray-500 dark:text-gray-400">
              <p>Don't want to run it yourself?</p>
              <a
                href="#managed"
                class="text-teal-600 dark:text-teal-400 hover:underline font-medium"
                >We'll manage it for you &rarr;</a
              >
            </div>
          </div>
        </div>

        <!-- 30-day money-back guarantee (low-key trust strip) -->
        <div
          class="max-w-4xl mx-auto mt-8 rounded-lg border border-gray-200 dark:border-gray-800 px-5 py-4 flex flex-col md:flex-row md:items-center gap-3 text-sm text-gray-600 dark:text-gray-400 text-center md:text-left"
          data-aos="fade-up"
        >
          <div
            class="flex items-center justify-center md:justify-start gap-2 shrink-0"
          >
            <svg
              class="w-5 h-5 text-teal-500 shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M12 2.5l8 3v6.2c0 4.7-3.3 8.6-8 9.8-4.7-1.2-8-5.1-8-9.8V5.5l8-3z"
              ></path>
              <path d="M9 12.2l2.2 2.2L15.5 10"></path>
            </svg>
            <span class="font-medium text-gray-900 dark:text-gray-100"
              >30-day money-back guarantee</span
            >
          </div>
          <span class="flex-1">
            Buy a Lifetime room risk-free. If it doesn't fit your venue in the
            first 30 days, email us and we'll refund every penny.
          </span>
        </div>

        <!-- More options (lower priority) -->
        <div class="max-w-4xl mx-auto mt-12">
          <h2
            class="text-sm uppercase tracking-wide font-semibold text-gray-500 dark:text-gray-400 mb-4 text-center"
            data-aos="fade-up"
          >
            More options
          </h2>
          <div class="grid gap-4 md:grid-cols-2">
            <!-- Day pass -->
            <div
              class="rounded-lg border border-gray-200 dark:border-gray-800 p-5 flex flex-col"
              data-aos="fade-up"
            >
              <div class="flex items-baseline justify-between mb-1">
                <p class="font-semibold text-gray-900 dark:text-gray-100">
                  Day pass
                </p>
                <p class="font-semibold text-gray-900 dark:text-gray-100">
                  &pound;29<span
                    class="text-sm font-normal text-gray-500 dark:text-gray-400"
                    >/day</span
                  >
                </p>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-400 mb-3 flex-1">
                One event, 24 hours, full Lifetime features including the guest
                portal. Great for conferences, weddings, and single-day hires.
              </p>
              <a
                class="text-sm text-teal-600 dark:text-teal-400 hover:underline font-medium"
                href="mailto:hello@theopenpresenter.com?subject=Day%20pass"
              >
                Book a day &rarr;
              </a>
            </div>

            <!-- Managed self-host -->
            <div
              id="managed"
              class="rounded-lg border border-gray-200 dark:border-gray-800 p-5 flex flex-col scroll-mt-24"
              data-aos="fade-up"
            >
              <div class="flex items-baseline justify-between mb-1">
                <p class="font-semibold text-gray-900 dark:text-gray-100">
                  Managed self-host
                </p>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-400 mb-3 flex-1">
                Self-hosted, but we own it. We install it on your
                infrastructure, then keep it updated, monitored, and backed up,
                with priority support.
              </p>
              <a
                class="text-sm text-teal-600 dark:text-teal-400 hover:underline font-medium"
                href="mailto:hello@theopenpresenter.com?subject=Managed%20self-host"
              >
                Talk to us &rarr;
              </a>
            </div>


          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What counts as a room -->
  <section class="relative">
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
      <div class="pb-12 md:pb-20">
        <div class="max-w-3xl mx-auto">
          <h2 class="h2 font-red-hat-display mb-4" data-aos="fade-up">
            What counts as a "room"?
          </h2>
          <p
            class="text-gray-600 dark:text-gray-400 mb-4"
            data-aos="fade-up"
            data-aos-delay="100"
          >
            A room is one logical presentation context. One synchronised show
            across as many physical screens as that room needs (main screen,
            confidence monitor, side panels, lobby signage). One booking, one
            guest, one show.
          </p>
          <p
            class="text-gray-600 dark:text-gray-400"
            data-aos="fade-up"
            data-aos-delay="150"
          >
            If you have two rooms running independent presentations at the same
            time, that's two rooms. Most small venues need 1&ndash;3.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="relative">
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
      <div class="pb-12 md:pb-20">
        <div class="max-w-3xl mx-auto">
          <h2 class="h2 font-red-hat-display mb-8" data-aos="fade-up">
            Pricing FAQ
          </h2>
          <div class="flex flex-col gap-4">
            <details
              class="rounded-lg border border-gray-200 dark:border-gray-800 p-5 group"
              data-aos="fade-up"
            >
              <summary
                class="cursor-pointer font-medium text-gray-900 dark:text-gray-100 flex items-center justify-between"
              >
                <span>What does buying a Lifetime room actually mean?</span>
                <span
                  class="ml-4 text-gray-400 group-open:rotate-45 transition-transform"
                  aria-hidden="true">+</span
                >
              </summary>
              <p class="text-sm text-gray-600 dark:text-gray-400 mt-3">
                You pay &pound;990 once per room and that room is yours for good
                with no monthly or yearly fee to keep it running. We treat it
                like the rest of your room kit: a one-time capital purchase, not
                a subscription you have to keep feeding. Bug fixes and security
                updates are always included.
              </p>
            </details>

            <details
              class="rounded-lg border border-gray-200 dark:border-gray-800 p-5 group"
              data-aos="fade-up"
            >
              <summary
                class="cursor-pointer font-medium text-gray-900 dark:text-gray-100 flex items-center justify-between"
              >
                <span>Can I pay monthly instead of buying outright?</span>
                <span
                  class="ml-4 text-gray-400 group-open:rotate-45 transition-transform"
                  aria-hidden="true">+</span
                >
              </summary>
              <p class="text-sm text-gray-600 dark:text-gray-400 mt-3">
                Yes. A room is &pound;79/month if you'd rather spread the cost,
                with no lock-in. Cancel any time. It's the same room and
                features as Lifetime; you're just renting rather than owning.
                Buy the Lifetime licence whenever you're ready to stop paying
                monthly.
              </p>
            </details>

            <details
              class="rounded-lg border border-gray-200 dark:border-gray-800 p-5 group"
              data-aos="fade-up"
            >
              <summary
                class="cursor-pointer font-medium text-gray-900 dark:text-gray-100 flex items-center justify-between"
              >
                <span>Can I self-host TheOpenPresenter?</span>
                <span
                  class="ml-4 text-gray-400 group-open:rotate-45 transition-transform"
                  aria-hidden="true">+</span
                >
              </summary>
              <p class="text-sm text-gray-600 dark:text-gray-400 mt-3">
                Yes. It's open source, so you can run the whole thing on your
                own hardware for free. Your data never leaves your network, and
                there are no per-room limits. You handle updates, backups, and
                support yourself. If you'd rather not, our Managed self-host
                option has us install it on your infrastructure and keep it
                updated, monitored, and backed up, with priority support.
                <a
                  href="mailto:hello@theopenpresenter.com?subject=Managed%20self-host"
                  class="text-teal-600 dark:text-teal-400 hover:underline font-medium"
                  >Email us</a
                > for a quote.
              </p>
            </details>

            <details
              class="rounded-lg border border-gray-200 dark:border-gray-800 p-5 group"
              data-aos="fade-up"
            >
              <summary
                class="cursor-pointer font-medium text-gray-900 dark:text-gray-100 flex items-center justify-between"
              >
                <span>Can I stay on Free forever?</span>
                <span
                  class="ml-4 text-gray-400 group-open:rotate-45 transition-transform"
                  aria-hidden="true">+</span
                >
              </summary>
              <p class="text-sm text-gray-600 dark:text-gray-400 mt-3">
                Yes. Free covers signage and basic presentation use with no time
                limit. Most people buy a Lifetime room for one of two reasons:
                they need the guest portal (a link your guest presenters use to
                upload and run their own slides), or they want to run a main
                screen, confidence monitor, and signage together as one
                synchronised show.
              </p>
            </details>

            <details
              class="rounded-lg border border-gray-200 dark:border-gray-800 p-5 group"
              data-aos="fade-up"
            >
              <summary
                class="cursor-pointer font-medium text-gray-900 dark:text-gray-100 flex items-center justify-between"
              >
                <span>How many displays can one room run?</span>
                <span
