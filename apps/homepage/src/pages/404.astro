---
import DefaultLayout from "../layouts/DefaultLayout.astro";
import PageIllustration from "../components/PageIllustration.astro";
---

<DefaultLayout title="Page Not Found | TheOpenPresenter">
  <!-- Page illustration -->
  <div
    class="relative max-w-6xl mx-auto h-0 pointer-events-none -z-1"
    aria-hidden="true"
  >
    <PageIllustration />
  </div>
  <section class="relative">
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
      <div class="pt-32 pb-12 md:pt-40 md:pb-20 text-center">
        <div class="max-w-3xl mx-auto">
          <h1 class="text-8xl font-black text-gray-400 mb-4">404</h1>
          <h2 class="h1 font-red-hat-display mb-4">Page Not Found</h2>
          <p class="text-xl text-gray-600 dark:text-gray-400 mb-8">
            The page you're looking for doesn't exist or has been moved.
          </p>
          <a
            class="btn text-white bg-teal-500 hover:bg-teal-400 inline-flex items-center"
            href="/"
          >
            <svg
              class="w-3 h-3 shrink-0 mr-2 rotate-180"
              viewBox="0 0 12 12"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                class="fill-current"
                d="M6.602 11l-.875-.864L9.33 6.534H0v-1.25h9.33L5.727 1.693l.875-.875 5.091 5.091z"
              ></path>
            </svg>
            <span>Back to Home</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>
