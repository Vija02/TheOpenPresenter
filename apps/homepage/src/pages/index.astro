---
import DefaultLayout from "../layouts/DefaultLayout.astro";
import PageIllustration from "../components/PageIllustration.astro";
import HeroHome from "../components/HeroHome.astro";
import HowItWorks from "../components/HowItWorks.astro";
import FeaturesBlocks from "../components/FeaturesBlocks.astro";
import TestimonialsBlocks from "../components/TestimonialsBlocks.astro";
import CtaSignup from "../components/CtaSignup.astro";
---

<DefaultLayout>
  <!-- Page illustration -->
  <div
    class="relative max-w-6xl mx-auto h-0 pointer-events-none -z-1"
    aria-hidden="true"
  >
    <PageIllustration />
  </div>
  <HeroHome />
  <HowItWorks />
  <FeaturesBlocks />
  <TestimonialsBlocks />
  <CtaSignup />
</DefaultLayout>
