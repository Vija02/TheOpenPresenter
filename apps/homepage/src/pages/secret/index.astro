---
import DefaultLayout from "../../layouts/DefaultLayout.astro";
import PageIllustration from "../../components/PageIllustration.astro";
---

<DefaultLayout title="I see what you did there | TheOpenPresenter">
  <!-- Page illustration -->
  <div
    class="relative max-w-6xl mx-auto h-0 pointer-events-none -z-1"
    aria-hidden="true"
  >
    <PageIllustration />
  </div>
  <section class="relative">
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
      <div class="pt-32 pb-12 md:pt-40 md:pb-20 text-center">
        <div class="max-w-3xl mx-auto">
          <h1
            class="h1 font-red-hat-display mb-4 leading-tight"
            data-aos="fade-down"
          >
            I see what you
            <span
              class="bg-clip-text text-transparent bg-gradient-to-r from-teal-400 to-purple-500"
              >did there</span
            >! 👋
          </h1>
          <p
            class="text-xl text-gray-600 dark:text-gray-400 mb-4"
            data-aos="fade-down"
            data-aos-delay="150"
          >
            Nothing much to see here yet! That QR code was just for
            illustration.
          </p>
          <hr class="mb-10 border-gray-200 dark:border-gray-800" />
          <p
            class="text-lg text-gray-600 dark:text-gray-400 mb-4"
            data-aos="fade-down"
            data-aos-delay="225"
          >
            But since you went through the trouble, do me a favour. Go back to
            the thread you came from and drop a comment (or an upvote) so I know
            the easter egg worked. I'll be looking out for it 😉
          </p>
          <p
            class="text-sm text-gray-500 dark:text-gray-500"
            data-aos="fade-down"
            data-aos-delay="300"
          >
            P.S. I'd love to give you a discount for finding this, but we're not
            accepting payment yet. Check back soon!
          </p>
        </div>
        <div
          class="mt-10 max-w-xs mx-auto sm:max-w-none sm:inline-flex sm:justify-center"
          data-aos="fade-down"
          data-aos-delay="300"
        >
          <div>
            <a
              class="btn text-white bg-teal-500 hover:bg-teal-400 w-full mb-4 sm:w-auto sm:mb-0 inline-flex items-center"
              href="https://github.com/Vija02/TheOpenPresenter"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span>Star us on GitHub</span>
              <svg
                class="w-3 h-3 shrink-0 mt-px ml-2"
                viewBox="0 0 12 12"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  class="fill-current"
                  d="M6.602 11l-.875-.864L9.33 6.534H0v-1.25h9.33L5.727 1.693l.875-.875 5.091 5.091z"
                ></path>
              </svg>
            </a>
          </div>
          <div>
            <a
              class="btn text-white bg-gray-700 hover:bg-gray-600 w-full sm:w-auto sm:ml-4"
              href="/"
            >
              Take me to the real thing
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</DefaultLayout>
