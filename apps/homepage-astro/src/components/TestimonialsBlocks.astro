<section>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div
      class="py-12 md:py-20 border-t border-transparent dark:border-gray-800"
    >
      <!-- Testimonials -->
      <div
        class="max-w-sm mx-auto grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:gap-12 items-start sm:max-w-none md:max-w-2xl lg:max-w-none"
      >
        <!-- 1st testimonial -->
        <div class="text-center">
          <div class="relative inline-flex flex-col mb-4">
            <img
              class="rounded-full"
              src="/images/testimonial-1.jpg"
              width="56"
              height="56"
              alt="Testimonial 01"
            />
            <svg
              class="absolute top-0 right-0 mt-1 -mr-8"
              width="27"
              height="12"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                class="fill-current text-purple-500"
                d="M2.785 5.334C2.538 5.5-.2 2.944.011 2.646.826 1.483 2.183.836 3.62.5 5.064.158 6.582.117 7.92-.02c.017-.002.098.153.088.166-1.763 2.018-3.223 3.836-5.221 5.188zm3.676 6.519c-.862.184-1.937-3.403-1.07-3.711 3.422-1.22 7.078-1.671 10.728-1.766 3.655-.096 7.304.162 10.866.32.044.002.06.177.018.187-6.938 1.634-13.691 3.504-20.542 4.97z"
              ></path>
            </svg>
          </div>
          <blockquote class="text-xl text-gray-600 dark:text-gray-400">
            " Being able to work together online is really nice. It just makes
            preparing the slides so much easier "
          </blockquote>
          <div class="font-red-hat-display font-bold mt-2">
            <cite class="not-italic">—Andy Croll</cite>
          </div>
        </div>

        <!-- 2nd testimonial -->
        <div class="text-center">
          <div class="relative inline-flex flex-col mb-4">
            <img
              class="rounded-full"
              src="/images/testimonial-2.jpg"
              width="56"
              height="56"
              alt="Testimonial 02"
            />
            <svg
              class="absolute top-0 right-0 mt-1 -mr-8"
              width="27"
              height="12"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                class="fill-current text-purple-500"
                d="M2.785 5.334C2.538 5.5-.2 2.944.011 2.646.826 1.483 2.183.836 3.62.5 5.064.158 6.582.117 7.92-.02c.017-.002.098.153.088.166-1.763 2.018-3.223 3.836-5.221 5.188zm3.676 6.519c-.862.184-1.937-3.403-1.07-3.711 3.422-1.22 7.078-1.671 10.728-1.766 3.655-.096 7.304.162 10.866.32.044.002.06.177.018.187-6.938 1.634-13.691 3.504-20.542 4.97z"
              ></path>
            </svg>
          </div>
          <blockquote class="text-xl text-gray-600 dark:text-gray-400">
            " It was quite simple to use. Being able to see all the slides on
            the screen in one go is nice "
          </blockquote>
          <div class="font-red-hat-display font-bold mt-2">
            <cite class="not-italic">—Emily Chen</cite>
          </div>
        </div>

        <!-- 3rd testimonial -->
        <div class="text-center">
          <div class="relative inline-flex flex-col mb-4">
