---
import DefaultLayout from "../../layouts/DefaultLayout.astro";
import PageIllustration from "../../components/PageIllustration.astro";
---

<DefaultLayout title="Login Failed | TheOpenPresenter">
  <!-- Page illustration -->
  <div
    class="relative max-w-6xl mx-auto h-0 pointer-events-none -z-1"
    aria-hidden="true"
  >
    <PageIllustration />
  </div>
  <section class="relative">
    <!-- End background gradient (light version only) -->
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
      <div class="pt-32 pb-12 md:pt-40 md:pb-20 text-center">
        <div class="max-w-3xl mx-auto">
          <h1 class="h1 font-red-hat-display mb-4" data-aos="fade-down">
            Login not successful
          </h1>
          <p
            class="text-xl text-gray-600 dark:text-gray-400"
            data-aos="fade-down"
            data-aos-delay="150"
          >
            Something went wrong when trying to log into your account. Please
            try again
          </p>
        </div>
        <a
          class="btn text-white bg-teal-500 hover:bg-teal-400 inline-flex items-center"
          href="/o"
        >
          <span>Try again</span>
        </a>
      </div>
    </div>
  </section>
</DefaultLayout>
